# Pinata API Credentials
# Get your keys from: https://app.pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# Optional: ENS Update (if automating ENS text record updates)
# WARNING: Never commit your actual private key to the repository!
ENS_PRIVATE_KEY=your_ens_manager_private_key
ENS_RPC_URL=https://eth.llamarpc.com

# Optional: Analytics (if using custom analytics backend)
ANALYTICS_ENDPOINT=https://analytics.u.onl/track
GA_TRACKING_ID=G-XXXXXXXXXX
